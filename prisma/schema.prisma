model SellerProperty {
  id            Int          @id @default(autoincrement())
  userId        Int          @map("user_id")
  fristName     String?      @map("frist_name")
  lastName      String?      @map("last_name")
  email         String?
  aadharNumber  String?      @map("aadhar_number")
  contactNumber String?      @map("contact_number")
  price         Float?       @map("price")
  description   String?
  propertyType  PropertyType @map("property_type")
  userType      UserType     @map("user_type")
  address       String?
  city          String?
  pincode       String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @map("updated_at")

  user              User               @relation(fields: [userId], references: [id])
  propertyImages    PropertyImages[]
  propertyDocuments PropertyDocument[]
  buyerCarts        buyerCart[]
}

enum PropertyType {
  OPEN_LAND
  FLAT_HOUSE
  COMMERCIAL
}

enum UserType {
  PROPERTY_SALLER
  RENTAL
}

model PropertyImages {
  id               Int      @id @default(autoincrement())
  sellerPropertyId Int      @map("seller_property_id")
  path             String?
  imageType        String?  @map("image_type")
  fileType         String?  @map("file_type")
  fileName         String?  @map("file_name")
  order            Int?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  SellerProperty SellerProperty @relation(fields: [sellerPropertyId], references: [id])
}

model PropertyDocument {
  id               Int      @id @default(autoincrement())
  sellerPropertyId Int      @map("seller_property_id")
  path             String?
  fileType         String?  @map("file_type")
  fileName         String?  @map("file_name")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  SellerProperty SellerProperty @relation(fields: [sellerPropertyId], references: [id])
}

model buyerCart {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  sellerPropertyId Int      @map("seller_property_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  SellerProperty SellerProperty @relation(fields: [sellerPropertyId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
}

model projectManagement {
  id                       Int         @id @default(autoincrement())
  userId                   Int         @map("user_id")
  fristName                String?     @map("frist_name")
  lastName                 String?     @map("last_name")
  email                    String?
  contactNumber            String?     @map("contact_number")
  alternativeContactNumber String?     @map("alternative_contact_number")
  projectType              projectType @map("project_type")
  description              String?
  address                  String?
  city                     String?
  pincode                  String?
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @default(now()) @map("updated_at")

  user User @relation(fields: [userId], references: [id])
}

enum projectType {
  construction
  renovation
  interior_design
  inspection
}
