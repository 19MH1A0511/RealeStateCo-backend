generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      Int                 @id() @default(autoincrement())
  name                    String?             @db.VarChar(45)
  contactMobile           String?             @map("contact_mobile") @db.VarChar(45)
  alterativecontactMobile String?             @map("alterative_contact_mobile") @db.VarChar(45)
  email                   String?
  otp                     String?
  otpExpiry               DateTime?           @map("otp_expiry")
  isActive                Boolean             @default(false) @map("is_active")
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @default(now()) @map("updated_at")
  // tenants                 Tenant[]
  sellerProperties        SellerProperty[]
  buyerCarts              buyerCart[]
  projectManagements      projectManagement[]
}

